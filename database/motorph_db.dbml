  "payroll_runs"
  "payslips"
}

TableGroup "workflow_ops" [color: #f1c40f] {
  "notifications"
  "operational_events"
  "workforce_payroll_readiness"
}

TableGroup "audit_compliance" [color: #e74c3c] {
  "audit_logs"
}

Ref "fk_attendance_adjustments_employee": "employees"."employee_id" < "attendance_adjustments"."employee_id" [update: cascade, delete: cascade]
Ref "fk_attendance_adjustments_user": "users"."user_id" < "attendance_adjustments"."adjusted_by_user_id" [update: cascade, delete: set null]
Ref "fk_attendance_records_employee": "employees"."employee_id" < "attendance_records"."employee_id" [update: cascade, delete: cascade]
Ref "fk_audit_logs_user": "users"."user_id" < "audit_logs"."user_id" [update: cascade, delete: set null]
Ref "fk_deduction_brackets_deduction": "deductions"."deduction_id" < "deduction_brackets"."deduction_id" [update: cascade, delete: cascade]
Ref "fk_deductions_type": "deduction_types"."deduction_type_id" < "deductions"."deduction_type_id" [update: cascade, delete: restrict]
Ref "fk_employee_government_ids_employee": "employees"."employee_id" < "employee_government_ids"."employee_id" [update: cascade, delete: cascade]
Ref "fk_employee_schedules_employee": "employees"."employee_id" < "employee_schedules"."employee_id" [update: cascade, delete: restrict]
Ref "fk_employee_schedules_holiday": "holidays"."holiday_id" < "employee_schedules"."holiday_id" [update: cascade, delete: set null]
Ref "fk_employee_schedules_shift": "employee_shifts"."shift_id" < "employee_schedules"."shift_id" [update: cascade, delete: set null]
Ref "fk_employee_schedules_window": "schedule_windows"."schedule_window_id" < "employee_schedules"."schedule_window_id" [update: cascade, delete: cascade]
Ref "fk_employee_shifts_assigned_by_user": "users"."user_id" < "employee_shifts"."assigned_by_user_id" [update: cascade, delete: set null]
Ref "fk_employees_department": "departments"."department_id" < "employees"."department_id" [update: cascade, delete: set null]
Ref "fk_employees_supervisor": "employees"."employee_id" < "employees"."supervisor_employee_id" [update: cascade, delete: set null]
Ref "fk_leave_approvals_leave": "leaves"."leave_id" < "leave_approvals"."leave_id" [update: cascade, delete: cascade]
Ref "fk_leave_approvals_user": "users"."user_id" < "leave_approvals"."approved_by_user_id" [update: cascade, delete: restrict]
Ref "fk_leaves_employee": "employees"."employee_id" < "leaves"."employee_id" [update: cascade, delete: cascade]
Ref "fk_notifications_event": "operational_events"."event_id" < "notifications"."event_id" [update: cascade, delete: cascade]
Ref "fk_notifications_target_employee": "employees"."employee_id" < "notifications"."target_employee_id" [update: cascade, delete: cascade]
Ref "fk_operational_events_actor_user": "users"."user_id" < "operational_events"."actor_user_id" [update: cascade, delete: set null]
Ref "fk_overtime_requests_employee": "employees"."employee_id" < "overtime_requests"."employee_id" [update: cascade, delete: cascade]
Ref "fk_overtime_requests_user": "users"."user_id" < "overtime_requests"."approved_by_user_id" [update: cascade, delete: set null]
Ref "fk_payroll_deductions_deduction": "deductions"."deduction_id" < "payroll_deductions"."deduction_id" [update: cascade, delete: restrict]
Ref "fk_payroll_deductions_run_detail": "payroll_run_details"."run_detail_id" < "payroll_deductions"."run_detail_id" [update: cascade, delete: cascade]
Ref "fk_payroll_history_employee": "employees"."employee_id" < "payroll_history"."employee_id" [update: cascade, delete: restrict]
Ref "fk_payroll_history_run_detail": "payroll_run_details"."run_detail_id" < "payroll_history"."run_detail_id" [update: cascade, delete: set null]
Ref "fk_payroll_run_details_employee": "employees"."employee_id" < "payroll_run_details"."employee_id" [update: cascade, delete: restrict]
Ref "fk_payroll_run_details_run": "payroll_runs"."run_id" < "payroll_run_details"."run_id" [update: cascade, delete: cascade]
Ref "fk_payroll_runs_period": "payroll_periods"."period_id" < "payroll_runs"."period_id" [update: cascade, delete: restrict]
Ref "fk_payroll_runs_user": "users"."user_id" < "payroll_runs"."processed_by_user_id" [update: cascade, delete: set null]
Ref "fk_payslips_employee": "employees"."employee_id" < "payslips"."employee_id" [update: cascade, delete: cascade]
Ref "fk_payslips_run_detail": "payroll_run_details"."run_detail_id" < "payslips"."run_detail_id" [update: cascade, delete: cascade]
Ref "fk_role_permissions_permission": "permissions"."permission_id" < "role_permissions"."permission_id" [update: cascade, delete: cascade]
Ref "fk_role_permissions_role": "roles"."role_id" < "role_permissions"."role_id" [update: cascade, delete: cascade]
Ref "fk_schedule_windows_created_by": "users"."user_id" < "schedule_windows"."created_by_user_id" [update: cascade, delete: set null]
