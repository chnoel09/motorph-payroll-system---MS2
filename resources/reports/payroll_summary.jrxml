<!-- Created with Jaspersoft Studio version 6.20.6.final using JasperReports Library version 6.20.6-5c96b6aa8a39ac1dc6b6bea4b81168e16dd39231  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="payroll_summary" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="33333333-3333-3333-3333-333333333333">
	<parameter name="CUTOFF_PERIOD" class="java.lang.String"/>
	<parameter name="PERIOD_START" class="java.sql.Date"/>
	<parameter name="PERIOD_END" class="java.sql.Date"/>
	<parameter name="LOGO_URL" class="java.net.URL"/>
	<queryString>
		<![CDATA[SELECT
                ph.employee_id,
                CONCAT(e.first_name, ' ', e.last_name) AS employee_name,
                e.position,
                e.status AS employee_status,
                ph.cutoff_period,
                COALESCE(pp.period_start, ph.period_start) AS period_start,
                COALESCE(pp.period_end, ph.period_end) AS period_end,
                pp.period_id,
                COALESCE(pp.status, 'Payroll Finalized') AS payroll_period_status,
                pp.finalized_at,
                pr.run_id,
                CASE
                    WHEN pr.status = 'READY_ONLY_PROCESSED' THEN 'Ready Employees Processed'
                    WHEN pr.status = 'PROCESSED' THEN 'Payroll Finalized'
                    WHEN pr.status IS NULL THEN 'Payroll History Snapshot'
                    ELSE pr.status
                END AS payroll_run_status,
                CASE
                    WHEN pr.status = 'READY_ONLY_PROCESSED' THEN 'Controlled Ready-Only Payroll Run'
                    WHEN pr.status = 'PROCESSED' THEN 'Full Payroll Finalization'
                    WHEN pr.status IS NULL THEN 'Payroll History Snapshot'
                    ELSE pr.status
                END AS payroll_run_type,
                CASE
                    WHEN pr.status = 'READY_ONLY_PROCESSED'
                        THEN 'This controlled run includes only employees confirmed as Payroll Ready. Unresolved employees remain outside this payroll history snapshot.'
                    WHEN pr.status = 'PROCESSED'
                        THEN 'This report summarizes the finalized full-period payroll run.'
                    ELSE 'This report summarizes payroll history rows available for the selected cutoff and date range.'
                END AS run_scope_note,
                pr.processed_at,
                u.username AS processed_by_username,
                CONCAT(processor.first_name, ' ', processor.last_name) AS processed_by_name,
                ph.hours_worked,
                ph.basic_component,
                ph.allowance_component,
                ph.gross,
                ph.sss,
                ph.philhealth,
                ph.pagibig,
                ph.tax,
                ph.total_deductions,
                ph.net
            FROM payroll_history ph
            JOIN employees e
              ON e.employee_id = ph.employee_id
            LEFT JOIN payroll_periods pp
              ON pp.cutoff_period = ph.cutoff_period
             AND pp.period_start = ph.period_start
             AND pp.period_end = ph.period_end
            LEFT JOIN (
                SELECT r.*
                FROM payroll_runs r
                JOIN (
                    SELECT period_id, MAX(processed_at) AS latest_processed_at
                    FROM payroll_runs
                    GROUP BY period_id
                ) latest
                  ON latest.period_id = r.period_id
                 AND latest.latest_processed_at = r.processed_at
            ) pr
              ON pr.period_id = pp.period_id
            LEFT JOIN users u
              ON u.user_id = pr.processed_by_user_id
            LEFT JOIN employees processor
              ON processor.employee_id = u.employee_id
            WHERE ph.cutoff_period = $P{CUTOFF_PERIOD}
              AND ph.period_start = $P{PERIOD_START}
              AND ph.period_end = $P{PERIOD_END}
            ORDER BY e.last_name, e.first_name, ph.employee_id]]>
	</queryString>
