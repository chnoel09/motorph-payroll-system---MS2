<?xml version="1.0" encoding="UTF-8"?>
<!-- Created with Jaspersoft Studio version 6.20.6.final using JasperReports Library version 6.20.6-5c96b6aa8a39ac1dc6b6bea4b81168e16dd39231  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="timecard" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="22222222-2222-2222-2222-222222222222">
	<parameter name="EMPLOYEE_ID" class="java.lang.Integer"/>
	<parameter name="START_DATE" class="java.sql.Date"/>
	<parameter name="END_DATE" class="java.sql.Date"/>
	<parameter name="PERIOD_LABEL" class="java.lang.String"/>
	<parameter name="LOGO_URL" class="java.net.URL"/>
	<queryString>
		<![CDATA[SELECT
                e.employee_id,
                CONCAT(e.first_name, ' ', e.last_name) AS employee_name,
                e.position,
                d.department_name,
                ar.attendance_date AS schedule_date,
                COALESCE(es.rest_day, 0) AS rest_day,
                es.status AS schedule_status,
                sh.shift_name,
                DATE_FORMAT(sh.start_time, '%H:%i') AS scheduled_start,
                DATE_FORMAT(sh.end_time, '%H:%i') AS scheduled_end,
                sh.grace_minutes,
                h.holiday_name,
                h.holiday_type,
                ar.time_in,
                ar.time_out,
                CASE
                    WHEN ar.time_in IS NULL OR ar.time_out IS NULL
                         OR ar.time_in = '' OR ar.time_out = ''
                    THEN 0
                    ELSE ROUND(TIMESTAMPDIFF(
                        MINUTE,
                        STR_TO_DATE(ar.time_in, '%H:%i'),
                        STR_TO_DATE(ar.time_out, '%H:%i')
                    ) / 60, 2)
                END AS hours_worked,
                CASE
                    WHEN h.holiday_id IS NOT NULL THEN CONCAT('Holiday: ', h.holiday_name)
                    WHEN es.schedule_id IS NULL THEN 'No Assigned Schedule'
                    WHEN es.rest_day = 1 THEN 'Rest Day Attendance'
                    WHEN ar.time_in IS NULL OR ar.time_in = '' THEN 'Missing Time In'
                    WHEN ar.time_out IS NULL OR ar.time_out = '' THEN 'Missing Time Out'
                    WHEN sh.shift_id IS NOT NULL
                         AND STR_TO_DATE(ar.time_in, '%H:%i') >
                             ADDTIME(sh.start_time, SEC_TO_TIME(COALESCE(sh.grace_minutes, 0) * 60))
                    THEN 'Late'
                    WHEN sh.shift_id IS NOT NULL
                         AND STR_TO_DATE(ar.time_out, '%H:%i') < sh.end_time
                    THEN 'Undertime'
                    ELSE 'Complete'
                END AS attendance_status
            FROM employees e
            JOIN attendance_records ar
              ON ar.employee_id = e.employee_id
            LEFT JOIN departments d
              ON d.department_id = e.department_id
            LEFT JOIN employee_schedules es
              ON es.employee_id = ar.employee_id
             AND es.schedule_date = ar.attendance_date
            LEFT JOIN employee_shifts sh
              ON sh.shift_id = es.shift_id
            LEFT JOIN holidays h
              ON h.holiday_id = es.holiday_id
              OR h.holiday_date = ar.attendance_date
            WHERE e.employee_id = $P{EMPLOYEE_ID}
              AND ar.attendance_date BETWEEN $P{START_DATE} AND $P{END_DATE}
            ORDER BY ar.attendance_date]]>
	</queryString>
	<field name="employee_id" class="java.lang.Integer"/>
	<field name="employee_name" class="java.lang.String"/>
	<field name="position" class="java.lang.String"/>
	<field name="department_name" class="java.lang.String"/>
	<field name="schedule_date" class="java.sql.Date"/>
	<field name="rest_day" class="java.lang.Boolean"/>
	<field name="schedule_status" class="java.lang.String"/>
	<field name="shift_name" class="java.lang.String"/>
	<field name="scheduled_start" class="java.lang.String"/>
	<field name="scheduled_end" class="java.lang.String"/>
	<field name="grace_minutes" class="java.lang.Integer"/>
	<field name="holiday_name" class="java.lang.String"/>
	<field name="holiday_type" class="java.lang.String"/>
	<field name="time_in" class="java.lang.String"/>
	<field name="time_out" class="java.lang.String"/>
	<field name="hours_worked" class="java.math.BigDecimal"/>
	<field name="attendance_status" class="java.lang.String"/>
	<variable name="TOTAL_HOURS" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{hours_worked}]]></variableExpression>
	</variable>
