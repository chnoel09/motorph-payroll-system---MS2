<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="payslip" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="11111111-1111-1111-1111-111111111111">
	<parameter name="EMPLOYEE_ID" class="java.lang.Integer"/>
	<parameter name="CUTOFF_PERIOD" class="java.lang.String"/>
	<parameter name="LOGO_URL" class="java.net.URL"/>
	<queryString>
		<![CDATA[SELECT
                e.employee_id,
                CONCAT(e.first_name, ' ', e.last_name) AS employee_name,
                e.position,
                ph.cutoff_period,
                ph.period_start,
                ph.period_end,
                ph.hours_worked,
                ph.basic_component,
                ph.allowance_component,
                ph.gross,
                ph.sss,
                ph.philhealth,
                ph.pagibig,
                ph.tax,
                ph.total_deductions,
                ph.net
            FROM employees e
            JOIN payroll_history ph ON e.employee_id = ph.employee_id
            WHERE e.employee_id = $P{EMPLOYEE_ID}
              AND ($P{CUTOFF_PERIOD} IS NULL OR ph.cutoff_period = $P{CUTOFF_PERIOD})
            ORDER BY ph.cutoff_period DESC
            LIMIT 1]]>
	</queryString>
	<field name="employee_id" class="java.lang.Integer"/>
	<field name="employee_name" class="java.lang.String"/>
	<field name="position" class="java.lang.String"/>
	<field name="cutoff_period" class="java.lang.String"/>
	<field name="period_start" class="java.sql.Date"/>
	<field name="period_end" class="java.sql.Date"/>
	<field name="hours_worked" class="java.math.BigDecimal"/>
	<field name="basic_component" class="java.math.BigDecimal"/>
	<field name="allowance_component" class="java.math.BigDecimal"/>
	<field name="gross" class="java.math.BigDecimal"/>
	<field name="sss" class="java.math.BigDecimal"/>
	<field name="philhealth" class="java.math.BigDecimal"/>
	<field name="pagibig" class="java.math.BigDecimal"/>
	<field name="tax" class="java.math.BigDecimal"/>
	<field name="total_deductions" class="java.math.BigDecimal"/>
	<field name="net" class="java.math.BigDecimal"/>
